<?xml version="1.0" encoding="utf-8"?>
<!-- Root is transparent; the panel slides up to cover the screen, then slides back down. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_bg">

        <LinearLayout
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="36dp">

            <TextView
                android:id="@+id/openingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:textColor="@color/overlay_text"
                android:textSize="22sp"
                tools:text="Opening Instagram" />

            <TextView
                android:id="@+id/attemptsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/overlay_text_dim"
                android:textSize="14sp"
                tools:text="You've opened it 5 times in the last 24h" />

            <TextView
                android:id="@+id/lastOpenedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@color/overlay_text_dim"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Last opened 10m ago" />

            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="40dp">

                <View
                    android:id="@+id/breathCircle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/breath_circle" />

                <TextView
                    android:id="@+id/countdownText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="sans-serif-thin"
                    android:textColor="@color/overlay_countdown"
                    android:textSize="76sp"
                    tools:text="8" />
            </FrameLayout>

            <TextView
                android:id="@+id/breatheText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.03"
                android:text="@string/overlay_breathe"
                android:textColor="@color/overlay_text_dim"
                android:textSize="18sp" />

            <LinearLayout
                android:id="@+id/buttonsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="52dp"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Available immediately so you can back out without waiting. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/closeButton"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:text="@string/overlay_close"
                    android:textSize="16sp"
                    app:cornerRadius="26dp" />

                <!-- Revealed only after the countdown finishes. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:minHeight="48dp"
                    android:text="@string/overlay_open"
                    android:textColor="@color/overlay_text_dim"
                    android:visibility="invisible" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
